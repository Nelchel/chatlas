{
  "expo": {
    "name": "Chatlas",
    "slug": "cat-quest",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "backgroundColor": "#FF8C5A",
      "resizeMode": "contain"
    },
    "updates": {
      "enabled": false,
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "scheme": "com.catquest.app",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.catquest.app",
      "buildNumber": "7"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF8C5A"
      },
      "package": "com.chatlas.app",
      "versionCode": 9,
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Chatlas needs access to your camera to capture cat photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Chatlas needs your location to show cats near you.",
          "locationWhenInUsePermission": "Chatlas needs your location to show cats near you."
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-updates",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "e9654ced-d0fb-47a2-907d-65d7a6357aa0"
      }
    },
    "owner": "nelchel"
  }
}
